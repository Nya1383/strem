{
  "name": "strem",
  "version": "0.1.0",
  "description": "STREM — low-latency desktop & application streaming over WebRTC",
  "author": "STREM",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "pnpm typecheck && electron-vite build && electron-builder --win",
    "build:mac": "pnpm typecheck && electron-vite build && electron-builder --mac",
    "build:linux": "pnpm typecheck && electron-vite build && electron-builder --linux",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"*.{ts,js,cjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"*.{ts,js,cjs,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rimraf out dist .vite coverage"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "nanoid": "^5.0.7",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "rimraf": "^5.0.9",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.3",
    "@vitest/ui": "^2.0.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
