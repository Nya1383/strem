# ---------------------------------------------------------------------------
# STREM environment configuration.
# Copy this file to `.env` and adjust as needed. All values are optional —
# the app boots with sensible defaults if `.env` is missing.
# ---------------------------------------------------------------------------

# Signaling server port. Leave unset to auto-pick a free port at runtime.
# STREM_SIGNALING_PORT=4173

# Host the embedded signaling server binds to. Use 0.0.0.0 to allow other
# machines on your LAN to reach the room.
# STREM_SIGNALING_HOST=127.0.0.1

# Public base URL the broadcaster advertises in its shareable Stream ID.
# Defaults to ws://127.0.0.1:<port> when unset.
# STREM_PUBLIC_URL=ws://192.168.1.10:4173

# ---- ICE / NAT traversal -------------------------------------------------
# Comma-separated list of STUN server URLs.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional TURN server (recommended for reliable cross-network connectivity).
# Leave blank for LAN / same-network streaming.
# TURN_URL=turn:turn.example.com:3478?transport=udp
# TURN_USER=username
# TURN_CRED=credential

# Max log level for the main process: silly | debug | verbose | info | warn | error
LOG_LEVEL=info
